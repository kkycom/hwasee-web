rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 주의: Firestore 규칙은 매칭되는 모든 match 블록을 OR로 평가함
    // (더 구체적인 규칙이 우선하는 게 아님). 그래서 하위 경로를 개별 차단하려면
    // 상위에 `{document=**}` 같은 전체 허용 와일드카드를 절대 두면 안 되고,
    // 아래처럼 컬렉션을 하나씩 명시해야 함.

    // config: ai_config/used_openings/stats 등은 클라이언트가 직접 읽고 씀.
    // secrets(Claude API 키 등 평문 비밀값)만 예외적으로 완전 차단 —
    // Cloud Functions(getClaudeKeyStatus/setClaudeKey, Admin SDK)만 접근 가능.
    match /config/secrets {
      allow read, write: if false;
    }
    match /config/{configId} {
      allow read, write: if configId != 'secrets';
    }

    // users/point_ledger: 2026-07-04 익명 인증(auth_uid 바인딩) 도입 이후 실제
    // 소유권 검증 적용. auth_uid가 아직 null인 문서는 "선점 없음"으로 간주해
    // 계속 쓰기 허용(레거시 계정 첫 액션이 곧 바인딩). 기기 변경 재바인딩은
    // register/login/loginWithGoogle/loginWithKakao Cloud Function(Admin SDK,
    // 비밀번호나 실제 소셜 OAuth 검증 후에만) 전용으로 완전히 이관됨(2026-07-13).
    //
    // ⚠️ 2026-07-17 보강(간편가입 도입 계기 발견): create는 register 등 계정 생성이
    // 전부 Cloud Function으로 이관되며 클라이언트가 더 이상 호출할 이유가 없어져서
    // 완전 차단. update도 auth_uid/google_uid/kakao_uid를 더 엄격히 제한 —
    // 예전엔 "본인 문서 소유자면 어느 필드든 원하는 값으로" 쓸 수 있어서, users가
    // 공개 read인 걸 이용해 남의 google_uid/kakao_uid를 읽어다 자기(또는 미끼)
    // 계정에 그대로 복사해두면, 나중에 그 사람이 실제로 구글/카카오 로그인할 때
    // 미끼 계정으로 잘못 연결될 수 있는 사전 계정 탈취(pre-hijacking류) 위험이
    // 있었음. auth_uid는 "자기 자신의 현재 실제 세션으로만" 갱신 허용(레거시
    // 백필 패턴과 일치), google_uid/kakao_uid는 클라이언트가 값 자체를 아예
    // 못 건드리게 함(전부 Cloud Function 전용 필드).
    match /users/{uid} {
      allow read: if true;
      allow create: if false;
      allow update: if request.auth != null &&
        (resource.data.auth_uid == null || resource.data.auth_uid == request.auth.uid) &&
        (request.resource.data.auth_uid == resource.data.auth_uid || request.resource.data.auth_uid == request.auth.uid) &&
        request.resource.data.get('google_uid', null) == resource.data.get('google_uid', null) &&
        request.resource.data.get('kakao_uid', null) == resource.data.get('kakao_uid', null);
      allow delete: if request.auth != null &&
        (resource.data.auth_uid == null || resource.data.auth_uid == request.auth.uid);
    }
    match /point_ledger/{docId} {
      allow read: if true;
      allow create: if request.auth != null && (
        !exists(/databases/$(database)/documents/users/$(request.resource.data.user_id)) ||
        get(/databases/$(database)/documents/users/$(request.resource.data.user_id)).data.auth_uid == null ||
        get(/databases/$(database)/documents/users/$(request.resource.data.user_id)).data.auth_uid == request.auth.uid
      );
      allow update, delete: if false; // 포인트 이력은 감사 추적용 — 수정/삭제 불가
    }

    // user_secrets(pw_hash/token): 2026-07-10 Auth 마이그레이션 5단계 — 완전 차단.
    // 예전엔 클라이언트가 로그인 시 직접 읽고 써야 해서 열어뒀었는데, 그 결과
    // 인증 없이 누구나 curl로 세션 토큰/비밀번호 해시를 읽을 수 있는 상태였음
    // (실제 노출 확인됨). pw_hash/token을 다루는 모든 경로(register/login/
    // verifySession/changePassword/resetPassword/deleteAccount)를 Cloud
    // Function(Admin SDK)으로 옮긴 뒤 여기를 잠금 — config/secrets와 동일 패턴.
    match /user_secrets/{docId} { allow read, write: if false; }

    // 그 외 컬렉션: 앱이 Firebase Auth를 쓰지 않고 자체 발급 user_id(localStorage)로
    // 신원을 관리하는 구조라 request.auth 기반 소유권 검증이 불가능함.
    // (실제 소유권/역할 검증을 하려면 Firebase Auth 도입이 선행되어야 함 — 별도 논의 필요)
    // stories는 다른 컬렉션처럼 완전 개방이지만, "오늘의 이야기" 스포트라이트
    // 슬롯(vote_threshold 필드로 식별)만은 예외 — 2026-07-14, 이 필드를 가진
    // 스토리가 원인불명으로 반복해서 status:'inactive'/'completed'로 바뀌는
    // 사고가 있었음(관리자 종료 버튼에서도 제외했지만, stories 전체가 인증
    // 없이 누구나 직접 쓸 수 있는 구조라 앱 밖에서의 쓰기도 막아야 확실함).
    // 우리 서버(Cloud Functions)는 Admin SDK를 쓰므로 이 규칙을 우회해서
    // 정상적인 스포트라이트 완결 처리는 그대로 동작함 — 여기서 막히는 건
    // 클라이언트/외부에서 오는 쓰기뿐.
    match /stories/{docId} {
      allow read: if true;
      allow create, delete: if true;
      allow update: if !(
        resource.data.get('vote_threshold', 0) > 0 &&
        resource.data.status == 'active' &&
        (request.resource.data.status == 'inactive' || request.resource.data.status == 'completed')
      );
    }
    match /episodes/{docId} { allow read, write: if true; }
    match /submissions/{docId} { allow read, write: if true; }
    match /votes/{docId} { allow read, write: if true; }
    match /comments/{docId} { allow read, write: if true; }
    match /bookmarks/{docId} { allow read, write: if true; }
    match /notifications/{docId} { allow read, write: if true; }
    match /story_likes/{docId} { allow read, write: if true; }
    match /story_mvp/{docId} { allow read, write: if true; }
    match /boosts/{docId} { allow read, write: if true; }
    match /extra_submits/{docId} { allow read, write: if true; }
    match /reports/{docId} { allow read, write: if true; }
    match /bug_reports/{docId} { allow read, write: if true; }
    match /patch_notes/{docId} { allow read, write: if true; }
    match /admin_edits/{docId} { allow read, write: if true; }
    match /visits/{docId} { allow read, write: if true; }
    match /account_deletion_reasons/{docId} { allow read, write: if true; }
    match /word_challenge_sets/{docId} { allow read, write: if true; }
    match /word_challenges/{docId} { allow read, write: if true; }
    match /word_challenge_submissions/{docId} { allow read, write: if true; }
    match /word_challenge_votes/{docId} { allow read, write: if true; }
    match /spotlight_word_pool/{docId} { allow read, write: if false; }
    match /spotlight_sentence_pool/{docId} { allow read, write: if false; }
    match /sentence_rounds/{docId} { allow read, write: if true; }
    match /sentence_round_submissions/{docId} { allow read, write: if true; }
    match /sentence_round_votes/{docId} { allow read, write: if true; }
    // 비밀번호 재설정 토큰 — 이메일 링크를 통해서만 소진돼야 하므로 클라이언트가
    // 직접 읽거나 쓸 이유가 전혀 없음(resetPasswordWithToken Cloud Function 전용).
    match /password_reset_tokens/{docId} { allow read, write: if false; }
    // 이메일 발송 rate limit 카운터 — findId/sendPasswordResetEmail Cloud Function
    // 전용(클라이언트가 직접 읽으면 남의 이메일 존재 여부/발송 이력이 새어나감).
    match /email_rate_limits/{docId} { allow read, write: if false; }
    match /story_visits/{docId} { allow read, write: if true; }
    // 스포트라이트 이야기 장르 확률 이력 — Cloud Function(_classifyStoryGenre,
    // Admin SDK)만 씀. 클라이언트는 카드/상세페이지 표시용으로 읽기만 함.
    match /story_genre_probs/{docId} { allow read: if true; allow write: if false; }
    // 공동집필 실시간 "쓰는 중" 표시용 — 8초 TTL(클라이언트가 최근 ping만
    // 신뢰) 방식이라 story_visits 등과 동일하게 민감정보 없음, 열어둠.
    match /episode_typing/{docId} { allow read, write: if true; }
  }
}
